# Factory API Keys - Copy to api_keys.env and fill in values
# DO NOT commit api_keys.env!

# moos local development database password (required by platform/presets/windows-local-dev.json)
MOOS_DB_PASSWORD=

# Google AI Studio (Gemini)
GEMINI_API_KEY=

# Google Cloud (for Vertex AI)
GOOGLE_APPLICATION_CREDENTIALS=D:/FFS0_Factory/moos/secrets/gcp-service-account.json

# OpenAI (optional)
OPENAI_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=
