{
  "id": "linux-service",
  "platform": "linux",
  "description": "Service-style Linux preset for running the moos kernel under a managed runtime environment.",
  "launcher": {
    "type": "service",
    "binary": "./moos-kernel",
    "workingDirectory": "/opt/moos"
  },
  "env": {
    "MOOS_HTTP_PORT": "8000",
    "MOOS_AGENT_PORT": "8004",
    "MOOS_MCP_PORT": "8080",
    "MOOS_NANOCLAW_PORT": "18789",
    "MOOS_DATABASE_URL": "postgres://moos:${MOOS_DB_PASSWORD}@db.internal:5432/moos?sslmode=require"
  },
  "services": {
    "database": "managed-postgres",
    "migrations": "predeploy",
    "metrics": true
  },
  "notes": [
    "Intended for systemd/container-style runtime environments.",
    "Installer assets should map onto this preset rather than invent hidden defaults."
  ]
}
