{
  "id": "windows-local-dev",
  "platform": "windows",
  "description": "Local Windows development preset for running the moos kernel with external Postgres.",
  "launcher": {
    "type": "binary",
    "path": ".\\moos-kernel.exe",
    "fallback": "go run ./cmd/kernel"
  },
  "env": {
    "MOOS_HTTP_PORT": "8000",
    "MOOS_AGENT_PORT": "8004",
    "MOOS_MCP_PORT": "8080",
    "MOOS_NANOCLAW_PORT": "18789",
    "MOOS_DATABASE_URL": "postgres://postgres:postgres@localhost:5432/moos?sslmode=disable"
  },
  "services": {
    "database": "external-postgres",
    "migrations": true,
    "metrics": true
  },
  "notes": [
    "Use for local workstation runs.",
    "Promote platform-specific installer behavior only after it is captured here."
  ]
}
