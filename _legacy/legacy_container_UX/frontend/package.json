{
  "name": "tiny-data-collider-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:demo": "vite --mode demo --port 5174 --host",
    "dev:backend": "vite --mode development --host",
    "dev:cloud": "vite --mode cloud --host",
    "build": "tsc -b && vite build",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint . --report-unused-disable-directives",
    "types:generate": "openapi-typescript openapi-spec.json -o src/lib/generated-api-types.ts",
    "types:fetch": "curl --connect-timeout 5 --max-time 10 http://localhost:8000/openapi.json -o openapi-spec.json && npm run types:generate",
    "types:sync": "npm run types:fetch",
    "auth:inject": "node scripts/auth/inject-auth.js"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.26.1",
    "@google/genai": "^1.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@mlc-ai/web-llm": "^0.2.79",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@tanstack/react-query": "^5.45.0",
    "@xyflow/react": "^12.9.3",
    "framer-motion": "^12.23.24",
    "immer": "^10.1.1",
    "lucide-react": "^0.471.0",
    "react": "^18.3.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "shiki": "^1.0.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.4.40",
    "run": "^1.5.0",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.20.6",
    "typecheck": "^0.1.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.47.0",
    "vite": "^5.4.11",
    "ws": "^8.18.3"
  }
}
