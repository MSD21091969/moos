{
    "version": "2.0.0",
    "tasks": [
        // ═══════════════════════════════════════════════════════════
        // 🎮 ONE-CLICK: Full debug environment in one command
        // ═══════════════════════════════════════════════════════════
        {
            "label": "🎮 Start: Demo + Edge Debug",
            "type": "shell",
            "command": ".\\scripts\\start-demo-debug.ps1",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": [],
            "detail": "Demo Mode: Kills processes → Starts Frontend (no backend) → Waits for ready → Launches Edge with CDP 9222"
        },
        {
            "label": "🎮 Start: Debug Session (All-in-One)",
            "type": "shell",
            "command": ".\\scripts\\start-debug-session.ps1",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": [],
            "detail": "Full Stack: Kills processes → Starts Backend → Starts Frontend → Launches Edge with CDP 9222"
        },
        // ═══════════════════════════════════════════════════════════
        // DEBUG: Browser inspection and Edge DevTools
        // ═══════════════════════════════════════════════════════════
        {
            "label": "Debug: Launch Chromium (CDP 9222)",
            "type": "shell",
            "command": ".\\scripts\\launch-debug-edge.ps1",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": [],
            "detail": "Closes all Edge windows first, then launches with --remote-debugging-port=9222. MCP Playwright uses this browser."
        },
        // ═══════════════════════════════════════════════════════════
        // MCP OBSERVATION: Real-time UX tracking for Phase 1
        // ═══════════════════════════════════════════════════════════
        {
            "label": "🔍 MCP: Inject Observer",
            "type": "shell",
            "command": "npx tsx scripts/inject-observer.ts",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": [],
            "detail": "Injects observer script into browser. Copilot can then use browser_console_messages to see [CLICK], [NAV], [STATE], [ERROR] events in real-time."
        },
        {
            "label": "🔍 MCP: Poll State",
            "type": "shell",
            "command": "npx tsx scripts/poll-state.ts",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": [],
            "detail": "Quick snapshot of current browser state: URL, Zustand store, localStorage, breadcrumb."
        },
        {
            "label": "🔍 MCP: Phase 1 Setup",
            "dependsOn": ["Start: Demo Mode", "Debug: Launch Chromium (CDP 9222)", "🔍 MCP: Inject Observer"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "detail": "Full Phase 1 setup: Demo Mode → Edge → Inject Observer. Ready for MCP-assisted UX testing."
        },
        // NOTE: Debug: Watch Console REMOVED - Use MCP browser_console_messages instead
        // NOTE: Debug: Check localStorage REMOVED - Use MCP browser_evaluate with window.__workspaceStore instead
        {
            "label": "Debug: Clear Storage & Reload",
            "type": "shell",
            "command": "npx tsx scripts/clear-storage.ts",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": [],
