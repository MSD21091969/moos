        {
            "label": "Start: Testing Session",
            "dependsOn": ["Clean: Kill All Processes", "Start: Full Stack"],
            "dependsOrder": "sequence",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": []
        },
        {
            "label": "Start: Full Stack",
            "dependsOn": ["Start: Backend", "Start: Frontend"],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "Start: Demo Mode",
            "type": "shell",
            "dependsOn": ["Clean: Kill All Processes"],
            "command": "$env:VITE_MODE='demo'; npm run dev",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$", "file": 1, "location": 2, "message": 3 },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE.*ready",
                    "endsPattern": "Local:.*http://localhost:5173"
                }
            }
        },
        {
            "label": "Start: Cloud Mode",
            "dependsOn": ["Clean: Kill All Processes", "Start: Backend (Cloud)", "Start: Frontend (Cloud)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Start: Backend (Cloud)",
            "type": "shell",
            "command": "cd '${workspaceFolder}/backend'; $env:USE_FIRESTORE_MOCKS='false'; $env:ENVIRONMENT='production'; python -m uvicorn src.main:app --reload --host 127.0.0.1 --port 8000",
            "options": { "cwd": "${workspaceFolder}/backend" },
            "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$", "file": 1, "location": 2, "message": 3 },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^INFO:\\s+Will watch for changes",
                    "endsPattern": "^INFO:\\s+Application startup complete"
                }
            }
        },
        {
            "label": "Start: Frontend (Cloud)",
            "type": "shell",
            "command": "$env:VITE_MODE='production'; npm run dev",
            "options": { "cwd": "${workspaceFolder}/frontend" },
            "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$", "file": 1, "location": 2, "message": 3 },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE.*ready",
                    "endsPattern": "Local:.*http://localhost:5173"
                }
            }
        },
        {
            "label": "Start: Backend",
            "type": "shell",
            "command": "cd '${workspaceFolder}/backend'; $env:USE_FIRESTORE_MOCKS='true'; $env:ENVIRONMENT='development'; $env:SKIP_AUTH_FOR_TESTING='true'; python -m uvicorn src.main:app --reload --host 127.0.0.1 --port 8000",
            "options": { "cwd": "${workspaceFolder}/backend" },
            "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
            "isBackground": true,
            "problemMatcher": {
                "pattern": { "regexp": "^$", "file": 1, "location": 2, "message": 3 },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^INFO:\\s+Will watch for changes",
                    "endsPattern": "^INFO:\\s+Application startup complete"
