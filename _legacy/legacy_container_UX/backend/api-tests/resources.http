# Resources API - Universal Object Model
# Usage: Set authToken in http-client.env.json after login

### List All Sessions
# @name listSessions
GET {{baseUrl}}/api/v2/resources
  ?type=session
Authorization: Bearer {{authToken}}

### Get Single Resource
# @name getResource
GET {{baseUrl}}/api/v2/resources/{{resourceId}}
Authorization: Bearer {{authToken}}

### Create Session
# @name createSession
POST {{baseUrl}}/api/v2/resources
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "type": "session",
  "name": "Test Session",
  "description": "Created via httpYac"
}

### Create Agent (child of session)
# @name createAgent
POST {{baseUrl}}/api/v2/resources
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "type": "agent",
  "name": "Test Agent",
  "parent_id": "{{sessionId}}",
  "config": {
    "model": "gemini-1.5-pro"
  }
}

### Update Resource
# @name updateResource
PATCH {{baseUrl}}/api/v2/resources/{{resourceId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Updated Name"
}

### Delete Resource
# @name deleteResource
DELETE {{baseUrl}}/api/v2/resources/{{resourceId}}
Authorization: Bearer {{authToken}}
