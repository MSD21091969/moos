{
  "name": "collider-chrome-extension",
  "displayName": "Collider",
  "version": "0.1.0",
  "description": "Multi-Agent Chrome Extension for Collider",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "test": "jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "@langchain/core": "^1.1.19",
    "@langchain/google-genai": "^2.1.15",
    "@langchain/langgraph": "^0.2.0",
    "@plasmohq/messaging": "^0.6.0",
    "@plasmohq/storage": "^1.12.0",
    "plasmo": "^0.89.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.278",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.0"
  },
  "manifest": {
    "permissions": [
      "storage",
      "sidePanel",
      "tabs",
      "activeTab",
      "nativeMessaging"
    ],
    "host_permissions": [
      "http://localhost:*/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  },
  "optionalDependencies": {
    "@img/sharp-win32-x64": "^0.34.5"
  }
}
