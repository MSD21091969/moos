{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Inspect platform presets",
            "type": "shell",
            "command": "Get-ChildItem -Path platform/presets",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Inspect secrets templates",
            "type": "shell",
            "command": "Get-ChildItem -Path secrets",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Inspect active .agent surfaces",
            "type": "shell",
            "command": "Get-ChildItem -Path .agent/knowledge_base, .agent/configs",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        }
    ]
}