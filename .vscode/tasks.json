{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "UV Sync (FFS0 - agent-factory)",
            "type": "shell",
            "command": "uv sync",
            "options": {
                "cwd": "${workspaceFolder:FFS0_Factory}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "UV Sync (FFS1 - ColliderDataSystems)",
            "type": "shell",
            "command": "uv sync",
            "options": {
                "cwd": "${workspaceFolder:FFS1_ColliderDataSystems}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "pnpm Install (Frontend)",
            "type": "shell",
            "command": "pnpm install",
            "options": {
                "cwd": "${workspaceFolder:FFS3_Frontend}/collider-frontend"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Nx Dev Portal (Frontend)",
            "type": "shell",
            "command": "pnpm nx dev portal",
            "options": {
                "cwd": "${workspaceFolder:FFS3_Frontend}/collider-frontend"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Nx Build Portal (Frontend)",
            "type": "shell",
            "command": "pnpm nx build portal",
            "options": {
                "cwd": "${workspaceFolder:FFS3_Frontend}/collider-frontend"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Nx Test Portal (Frontend)",
            "type": "shell",
            "command": "pnpm nx test portal",
            "options": {
                "cwd": "${workspaceFolder:FFS3_Frontend}/collider-frontend"
            },
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Pytest (FFS0)",
            "type": "shell",
            "command": "uv run pytest -v",
            "options": {
                "cwd": "${workspaceFolder:FFS0_Factory}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Pytest (FFS1)",
            "type": "shell",
            "command": "uv run pytest -v",
            "options": {
                "cwd": "${workspaceFolder:FFS1_ColliderDataSystems}"
            },
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Start ColliderDataServer (port 8000)",
            "type": "shell",
            "command": "uv run uvicorn src.main:app --reload --port 8000",
            "options": {
                "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderDataServer"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start ColliderGraphToolServer (port 8001)",
            "type": "shell",
            "command": "uv run uvicorn src.main:app --reload --port 8001",
            "options": {
                "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderGraphToolServer"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start ColliderVectorDbServer (port 8002)",
            "type": "shell",
            "command": "uv run uvicorn src.main:app --reload --port 8002",
            "options": {
                "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderVectorDbServer"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Plasmo Dev (Chrome Extension)",
            "type": "shell",
            "command": "pnpm plasmo dev",
            "options": {
                "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderMultiAgentsChromeExtension"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Plasmo Build (Chrome Extension)",
            "type": "shell",
            "command": "pnpm plasmo build",
            "options": {
                "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderMultiAgentsChromeExtension"
            },
            "group": "build",
            "problemMatcher": []
        }
    ]
}