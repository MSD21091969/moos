{
  "files.associations": {
    "**/.agent/**/*.md": "markdown",
    "**/.agent/**/*.yaml": "yaml",
    "**/TESTING.md": "markdown",
    "**/CLAUDE.md": "markdown"
  },
  "search.exclude": {
    "**/.venv": true,
    "**/__pycache__": true,
    "**/*.egg-info": true,
    "**/node_modules": true,
    "**/.nx": true,
    "**/build": true,
    "**/.plasmo": true,
    ".agent/instructions": true,
    ".agent/rules": true,
    ".agent/workflows": true,
    "workspaces/FFS1_ColliderDataSystems": true,
    "workspaces/maassen_hochrath": true
  },
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/node_modules/**": true,
    "**/.nx/**": true,
    "**/.plasmo/**": true,
    "workspaces/FFS1_ColliderDataSystems/**": true,
    "workspaces/maassen_hochrath/**": true
  },
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "file": ".github/copilot-instructions.md"
    }
  ],
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "text": "Check for: accidental edits to legacy paths, hardcoded secrets, preset/installer metadata drift, and consistency with the active surfaces (`platform`, `.agent/knowledge_base`, `.agent/knowledge`, `.agent/configs`, `.vscode`, `secrets`)."
    }
  ],
  "python.defaultInterpreterPath": ".venv/Scripts/python.exe",
  "ruff.path": [
    ".venv/Scripts/ruff.exe"
  ],
  "python.analysis.diagnosticMode": "openFilesOnly",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[typescript]": {
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.formatOnSave": true
  },
  "json.schemas": [
    {
      "fileMatch": [
        ".agent/knowledge_base/instances/*.json"
      ],
      "url": "./.agent/knowledge_base/registry/schema.json"
    }
  ],
  "files.readonlyInclude": {
    "**/.agent/knowledge_base/reference/**": true,
    "**/.agent/knowledge_base/registry/ontology.csv": true
  }
}