{
  "servers": {
    "collider-tools": {
      "type": "sse",
      "url": "http://localhost:8080/mcp/sse"
    },
    "filesystem-workspace": {
      "type": "stdio",
      "command": "C:/Program Files/nodejs/npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:/FFS0_Factory/moos/platform",
        "D:/FFS0_Factory/moos/.agent/knowledge_base",
        "D:/FFS0_Factory/moos/.agent/configs",
        "D:/FFS0_Factory/moos/.vscode",
        "D:/FFS0_Factory/moos/secrets"
      ]
    },
    "git-root": {
      "type": "stdio",
      "command": "C:/Program Files/nodejs/npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "--repository",
        "D:/FFS0_Factory/moos"
      ]
    },
    "http-fetch": {
      "type": "stdio",
      "command": "C:/Program Files/nodejs/npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    }
  }
}