{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ColliderDataServer (port 8000)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderDataServer",
            "envFile": "${workspaceFolder:FFS2_Backends+ChromeExt}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "ColliderGraphToolServer (port 8001)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--port",
                "8001"
            ],
            "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderGraphToolServer",
            "envFile": "${workspaceFolder:FFS2_Backends+ChromeExt}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "ColliderVectorDbServer (port 8002)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--port",
                "8002"
            ],
            "cwd": "${workspaceFolder:FFS2_Backends+ChromeExt}/ColliderVectorDbServer",
            "envFile": "${workspaceFolder:FFS2_Backends+ChromeExt}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "Pytest (FFS0)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-v"
            ],
            "cwd": "${workspaceFolder:FFS0_Factory}",
            "console": "integratedTerminal"
        },
        {
            "name": "Pytest (FFS1)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-v"
            ],
            "cwd": "${workspaceFolder:FFS1_ColliderDataSystems}",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "All Collider Backends",
            "configurations": [
                "ColliderDataServer (port 8000)",
                "ColliderGraphToolServer (port 8001)",
                "ColliderVectorDbServer (port 8002)"
            ],
            "stopAll": true
        }
    ]
}