# ==============================================================================
# API Configuration
# ==============================================================================
APP_TITLE=Collider API
APP_DESCRIPTION=Data-centric AI Tooling Framework with Casefile Workspaces
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_LOG_LEVEL=DEBUG
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# CORS - comma-separated origins
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================================================================
# Pydantic Logfire (Observability)
# ==============================================================================
# Get your token from: https://logfire.pydantic.dev/
# Development: Leave empty to use console-only logging
# Production: Set token to enable cloud logging
LOGFIRE_TOKEN=
ENVIRONMENT=development

# ==============================================================================
# Firestore Configuration
# ==============================================================================
# NEW STRATEGY (2025-11-10):
# - Local Development: Use REAL Firestore (easier than mocks)
# - Unit Tests: Use MockFirestore (fast, isolated)
# - Production: Use REAL Firestore with service account

GCP_PROJECT=mailmind-ai-djbuw
FIRESTORE_DATABASE=my-tiny-data-collider

# Local Development: Point to your service account JSON file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Place in project root (gitignored)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-dev.json

# Development: Set to FALSE to use real Firestore
# Only set to TRUE in unit test environment (tests/conftest.py)
USE_FIRESTORE_MOCKS=false

# Secret Manager (production only - requires GCP credentials)
# When enabled, secrets retrieved from GCP Secret Manager:
# - OPENAI_API_KEY, GOOGLE_API_KEY, LOGFIRE_API_KEY, SECRET_KEY
USE_SECRET_MANAGER=false  # Set to true in Cloud Run

# Firestore emulator (OPTIONAL - not recommended)
# Only use if you can't access real Firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ==============================================================================
# JWT Authentication (REQUIRED)
# ==============================================================================
# Development: Use JWT_SECRET_KEY directly
# Production: Use Secret Manager (recommended)

# Option 1: Direct secret key (development)
# Generate strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-only-secret-key-change-in-production-min-32-characters

# Option 2: Secret Manager (production - recommended)
# JWT_USE_SECRET_MANAGER=true
# JWT_SECRET_MANAGER_PROJECT=mailmind-ai-djbuw
# JWT_SECRET_MANAGER_SECRET_NAME=jwt-secret-key

JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ==============================================================================
# Rate Limiting (Deprecated - see Redis section)
# ==============================================================================
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60

# ==============================================================================
# Redis Cache & Rate Limiting
# ==============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_DEFAULT_TTL=300
REDIS_ENABLED=true

# Rate limiting (tier-based)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=300
RATE_LIMIT_ENTERPRISE=1000

# ==============================================================================
# Feature Flags
# ==============================================================================
FEATURE_ENABLE_MOCK_GMAIL=true
FEATURE_ENABLE_MOCK_DRIVE=true

# ==============================================================================
# Google OAuth (for Workspace APIs)
# ==============================================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add redirect URI: http://localhost:8000/oauth/callback (dev)
# 3. Download client_secret.json or copy credentials below

GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
