{
  "$schema": "../superset/schemas/instance.schema.json",
  "schema_version": "3.0",
  "domain": "providers",
  "description": "Provider instances — VALUE entries for Provider_p (CAT17) and adapter (CAT19) categories. Each provider is a container with OWNS wires to model containers. Adapter type maps to Go interface. Config source: .agent/configs/api_providers.yaml",
  "entries": [
    {
      "id": "urn:moos:provider:anthropic",
      "type_id": "provider",
      "name": "Anthropic",
      "adapter_type": "AnthropicAdapter",
      "api_base_url": "https://api.anthropic.com/v1",
      "auth_pattern": "x-api-key header",
      "config_source": ".agent/configs/api_providers.yaml#providers.anthropic",
      "rate_limits": {
        "requests_per_minute": 1000,
        "tokens_per_minute": 100000,
        "note": "Varies by tier — check dashboard"
      },
      "models": [
        {
          "id": "urn:moos:model:anthropic:claude-opus-4-6",
          "name": "claude-opus-4-6",
          "capabilities": [
            "complete",
            "stream",
            "tool_use",
            "extended_thinking"
          ],
          "context_window": 200000,
          "max_output_tokens": 32768
        },
        {
          "id": "urn:moos:model:anthropic:claude-sonnet-4-6",
