{
  "$schema": "../superset/schemas/instance.schema.json",
  "schema_version": "3.0",
  "role": "value-layer",
  "domain": "runtime_surfaces",
  "canonicality": "canonical-contingent",
  "source_refs": [
    "../superset/ontology.json"
  ],
  "entries": [
    {
      "id": "urn:moos:surface:kernel-http",
      "name": "MOOS Kernel HTTP",
      "type_id": "runtime_surface",
      "port": 8000,
      "protocol": "HTTP/REST",
      "entrypoints": [
        "/healthz",
        "/state",
        "/morphisms",
        "/programs",
        "/hydration/materialize"
      ],
      "implementation": "platform/kernel/cmd/kernel",
      "status": "live"
    },
    {
      "id": "urn:moos:surface:agent-compat",
      "name": "MOOS Agent Compatibility",
      "type_id": "runtime_surface",
      "port": 8004,
      "protocol": "HTTP/REST",
      "implementation": null,
      "status": "reserved-compatibility"
    },
    {
      "id": "urn:moos:surface:mcp-sse",
      "name": "MOOS MCP/SSE Compatibility",
      "type_id": "protocol_adapter",
      "port": 8080,
      "protocol": "SSE",
      "implementation": null,
      "status": "reserved-compatibility"
    },
    {
      "id": "urn:moos:surface:nanoclaw-bridge",
      "name": "MOOS NanoClaw Compatibility",
      "type_id": "protocol_adapter",
      "port": 18789,
      "protocol": "WebSocket/JSON-RPC",
      "implementation": null,
      "status": "reserved-compatibility"
    },
    {
      "id": "urn:moos:surface:explorer-ui",
      "name": "MOOS Runtime Explorer",
      "type_id": "ui_lens",
      "stratum": "S4",
      "port": 8000,
      "protocol": "HTTP/HTML",
      "entrypoints": [
        "/",
        "/explorer",
        "/hydration/examples/explorer-demo"
      ],
      "implementation": "platform/kernel/internal/transport/explorer.go",
      "status": "live-projection"
    }
  ]
}