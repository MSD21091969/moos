{
  "schema_version": "1.0",
  "layer": "values",
  "structure_ref": "../registry/ontology.json",
  "description": "User/system preferences — VALUE entries for runtime configuration. Each pref is a key-value pair with override scope (system, workspace, user, session). These are NOT containers — they are wire_config values on existing morphisms.",
  "scopes": {
    "system": "Built-in defaults — cannot be overridden by lower scopes",
    "workspace": "Per-workspace override — stored in manifest/env",
    "user": "Per-user override — stored in user profile container",
    "session": "Per-session override — ephemeral, lost on disconnect"
  },
  "preferences": [
    {
      "key": "model.default_provider",
      "type": "string",
      "default": "gemini",
      "allowed_values": [
        "anthropic",
        "gemini",
        "openai"
      ],
      "scope": "workspace",
      "description": "Default LLM provider for morphism dispatch",
      "wire_config_target": "can_execute wires on AgnosticModel"
    },
    {
      "key": "model.default_model",
      "type": "string",
      "default": "gemini-2.0-flash",
      "scope": "workspace",
      "description": "Default model within default provider",
      "wire_config_target": "can_execute wires on AgnosticModel"
    },
    {
      "key": "model.fallback_order",
      "type": "string[]",
      "default": [
        "gemini",
        "anthropic",
        "openai"
      ],
      "scope": "workspace",
      "description": "Provider fallback sequence on dispatch failure"
    },
    {
      "key": "model.benchmark_override",
      "type": "boolean",
      "default": false,
      "scope": "session",
      "description": "When true, dispatcher uses benchmark scores to select provider per-task instead of default"
    },
    {
      "key": "ui.graph_layout",
      "type": "string",
      "default": "dagre",
      "allowed_values": [
        "dagre",
        "elk",
        "force",
        "manual"
      ],
      "scope": "user",
      "description": "XYFlow graph layout algorithm"
    },
    {
      "key": "ui.theme",
      "type": "string",
      "default": "dark",
      "allowed_values": [
        "dark",
        "light",
        "system"
      ],
      "scope": "user",
      "description": "UI theme preference"
    },
    {
      "key": "ui.sidebar_width",
      "type": "number",
      "default": 400,
      "scope": "user",
      "description": "Agent chat sidebar width in pixels"
    },
    {
      "key": "agent.auto_execute_morphisms",
      "type": "boolean",
      "default": false,
      "scope": "session",
      "description": "When true, agent commits ADD/LINK/MUTATE/UNLINK without confirmation"
    },
    {
      "key": "agent.max_morphisms_per_turn",
      "type": "number",
      "default": 10,
      "scope": "workspace",
      "description": "Maximum morphisms the agent can produce in a single turn"
    },
    {
      "key": "agent.streaming_enabled",
      "type": "boolean",
      "default": true,
      "scope": "workspace",
      "description": "Use Stream() instead of Complete() for agent responses"
    },
    {
      "key": "graph.auto_embed",
      "type": "boolean",
      "default": true,
      "scope": "workspace",
      "description": "Automatically run F_embed on new containers"
    },
    {
      "key": "graph.max_scope_depth",
      "type": "number",
      "default": 5,
      "scope": "system",
      "description": "Maximum recursive CTE depth for Scoped(W) queries"
    }
  ]
}