{
  "$schema": "../registry/schemas/instance.schema.json",
  "schema_version": "3.0",
  "domain": "distribution",
  "role": "value-layer",
  "canonicality": "canonical-contingent",
  "entries": [
    {
      "id": "urn:moos:distribution:platform_distribution",
      "type_id": "distribution_config",
      "workspace_root": "D:/FFS0_Factory/moos",
      "active_platform_root": "kernel/",
      "kernel_module": "kernel",
      "windows_local_dev": {
        "default_store": "file",
        "log_path": "./kernel/data/morphism-log.jsonl",
        "registry_path": "../.agent/knowledge_base/registry/ontology.json",
        "database_mode": "optional; only required when MOOS_KERNEL_STORE=postgres"
      },
      "demo_seed": {
        "payload": "kernel/cmd/moos/main.go",
        "apply_endpoint": "/hydration/materialize"
      }
    }
  ]
}
