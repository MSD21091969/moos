{
  "$schema": "../superset/schemas/instance.schema.json",
  "schema_version": "3.0",
  "role": "value-layer",
  "domain": "identities",
  "canonicality": "canonical-contingent",
  "source_refs": [
    "../superset/ontology.json",
    "../../configs/users.yaml"
  ],
  "entries": [
    {
      "id": "urn:moos:user:demo-seeder",
      "type_id": "user",
      "system_profile": "local-dev-actor",
      "scope": "urn:moos:scope:explorer-demo",
      "used_by": [
        "platform/kernel/cmd/kernel/main.go"
      ],
      "status": "contingent-local-dev"
    },
    {
      "id": "urn:moos:admin:local-dev",
      "type_id": "collider_admin",
      "stratum": "S2",
      "system_profile": "local-dev-admin",
      "scope": "urn:moos:scope:explorer-demo",
      "allowed_morphism_roles": [
        "OWNS",
        "CAN_HYDRATE",
        "PRE_FLIGHT_CONFIG"
      ],
      "used_by": [
        "platform/kernel/cmd/kernel/main.go"
      ],
      "status": "contingent-local-dev"
    },
    {
      "id": "urn:moos:admin:root",
      "type_id": "superadmin",
      "stratum": "S2",
      "system_profile": "root-superadmin",
      "scope": "urn:moos:scope:global",
      "allowed_morphism_roles": [
        "OWNS",
        "CAN_HYDRATE",
        "PRE_FLIGHT_CONFIG",
        "CAN_SCHEDULE",
        "CAN_FEDERATE"
      ],
      "notes": "Transitive OWNS over all containers. Only one superadmin per kernel instance.",
      "status": "contingent-local-dev"
    }
  ],
  "notes": "type_id maps strictly to ontology.json objects. system_profile maps mapping to configs/users.yaml profiles."
}