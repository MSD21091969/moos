{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Knowledge Base Value Layer Schema",
  "description": "Support schema for publication and validation of value-layer JSON artifacts. Concrete contingent instances live in ../instances/.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "canonicality": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schema_version",
    "role",
    "canonicality",
    "source_refs"
  ]
}