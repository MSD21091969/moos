{
    "$id": "https://moos.factory/schemas/graph.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Mo:os Graph Substrate Schema",
    "description": "Defines the strictly valid graph primitives: Node, Wire, Envelope.",
    "definitions": {
        "URN": {
            "type": "string",
            "pattern": "^urn:moos:"
        },
        "Stratum": {
            "type": "string",
            "enum": [
                "S0",
                "S1",
                "S2",
                "S3",
                "S4"
            ]
        },
        "Node": {
            "type": "object",
            "required": [
                "urn",
                "type_id",
                "stratum"
            ],
            "properties": {
                "urn": {
                    "$ref": "#/definitions/URN"
                },
                "type_id": {
                    "type": "string"
                },
                "stratum": {
                    "$ref": "#/definitions/Stratum"
                },
                "payload": {
                    "type": "object"
                }
            }
        },
        "Wire": {
            "type": "object",
            "required": [
                "source_urn",
                "source_port",
                "target_urn",
                "target_port"
            ],
            "properties": {
                "source_urn": {
                    "$ref": "#/definitions/URN"
                },
                "source_port": {
                    "type": "string"
                },
                "target_urn": {
                    "$ref": "#/definitions/URN"
                },
                "target_port": {
                    "type": "string"
                }
            }
        },
        "Envelope": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "ADD",
                        "LINK",
                        "MUTATE",
                        "UNLINK"
                    ]
                },
                "actor": {
                    "$ref": "#/definitions/URN"
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "add": {
                    "$ref": "#/definitions/Node"
                },
                "link": {
                    "$ref": "#/definitions/Wire"
                },
                "mutate": {
                    "type": "object",
                    "required": [
                        "urn",
                        "payload"
                    ],
                    "properties": {
                        "urn": {
                            "$ref": "#/definitions/URN"
                        },
                        "payload": {
                            "type": "object"
                        }
                    }
                },
                "unlink": {
                    "$ref": "#/definitions/Wire"
                }
            }
        }
    }
}