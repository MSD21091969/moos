{
    "$id": "https://moos.factory/schemas/config.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Mo:os Environment Config Schema",
    "description": "Defines what a real-world binding to the graph looks like (.agent/configs/).",
    "type": "object",
    "properties": {
        "schema_version": {
            "type": "string"
        },
        "auth_profiles": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "properties": {
                    "method": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    }
                }
            }
        }
    }
}