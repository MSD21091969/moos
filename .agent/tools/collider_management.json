  {
    "name": "create_node",
    "description": "Create a new workspace node in the Collider graph with instructions, rules, and knowledge.",
    "params_schema": {
      "type": "object",
      "properties": {
        "app_id": {
          "type": "string",
          "description": "Application UUID"
        },
        "path": {
          "type": "string",
          "description": "Logical dot-path, e.g. factory/ffs1/my-node"
        },
        "parent_id": {
          "type": "string",
          "description": "Parent node UUID (optional)"
        },
        "kind": {
          "type": "string",
          "enum": [
            "workspace",
            "tool",
            "workflow"
          ],
          "default": "workspace",
          "description": "Semantic role of this node"
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Agent identity / system instructions (agents_md)"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Guardrails and constraints (soul_md)"
        },
        "knowledge": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Reference documentation (tools_md)"
        }
      },
      "required": [
        "app_id",
        "path"
      ]
    },
    "code_ref": "src.tools.collider_management:create_node",
    "visibility": "global"
  },
  {
    "name": "update_node",
    "description": "Update an existing node's instructions, rules, or knowledge (partial update).",
    "params_schema": {
      "type": "object",
      "properties": {
        "app_id": {
          "type": "string",
          "description": "Application UUID"
        },
        "node_id": {
          "type": "string",
          "description": "Node UUID to update"
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "New instructions (replaces existing)"
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "New rules (replaces existing)"
        },
        "knowledge": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "New knowledge docs (replaces existing)"
        }
      },
      "required": [
        "app_id",
        "node_id"
      ]
    },
    "code_ref": "src.tools.collider_management:update_node",
    "visibility": "global"
  },
