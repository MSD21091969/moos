{
    "manifest_version": 3,
    "name": "Collider Multi Agents Sidepanel",
    "version": "0.1.0",
    "description": "Chrome sidepanel wrapper for FFS4 runtime surface",
    "permissions": [
        "sidePanel"
    ],
    "host_permissions": [
        "http://localhost:4201/*",
        "http://127.0.0.1:4201/*"
    ],
    "background": {
        "service_worker": "service_worker.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "Open Collider Sidepanel"
    }
}