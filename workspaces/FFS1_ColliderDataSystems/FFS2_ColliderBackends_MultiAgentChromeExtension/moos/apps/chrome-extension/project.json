{
    "name": "@moos/chrome-extension",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "application",
    "sourceRoot": "apps/chrome-extension",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm --dir apps/chrome-extension build"
            }
        },
        "clean": {
            "executor": "nx:run-commands",
            "options": {
                "command": "pnpm --dir apps/chrome-extension clean"
            }
        }
    },
    "tags": [
        "scope:moos",
        "type:app"
    ]
}