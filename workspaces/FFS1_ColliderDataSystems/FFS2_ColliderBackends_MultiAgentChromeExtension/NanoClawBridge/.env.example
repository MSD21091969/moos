# Required: Anthropic API key for Claude Code CLI
ANTHROPIC_API_KEY=sk-ant-...

# NanoClawBridge WebSocket port (default: 18789)
NANOCLAWBRIDGE_PORT=18789

# Collider GraphToolServer MCP endpoint
COLLIDER_MCP_URL=http://localhost:8001/mcp/sse

# Path to workspaces written by ColliderAgentRunner
NANOCLAW_WORKSPACE_DIR=~/.nanoclaw/workspaces

# Context Delivery Mode (Dual Mode)
# Mode 1: Filesystem (Legacy) - USE_SDK_AGENT=false
# Mode 2: SDK + gRPC (Current) - USE_SDK_AGENT=true, USE_GRPC_CONTEXT=true
USE_SDK_AGENT=true
USE_GRPC_CONTEXT=true
GRPC_CONTEXT_ADDRESS=localhost:50051

# Collider Backend URLs
COLLIDER_DATA_SERVER_URL=http://localhost:8000
COLLIDER_AGENT_RUNNER_URL=http://localhost:8004

# Claude Code model (optional, defaults to claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Session idle timeout in minutes (default: 30)
# SESSION_IDLE_TIMEOUT_MINUTES=30
