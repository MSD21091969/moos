# Collider Development Environment
# Copy to .env and fill in your values

# Data Server
COLLIDER_DATABASE_URL=sqlite+aiosqlite:///./collider.db
COLLIDER_HOST=0.0.0.0
COLLIDER_PORT=8000
COLLIDER_DEBUG=true

# GraphTool Server
GRAPHTOOL_PORT=8001
GRAPHTOOL_DEFAULT_MODEL=gemini:gemini-3.1-pro
GRAPHTOOL_VECTORDB_URL=http://localhost:8002

# VectorDB Server
VECTORDB_PORT=8002
VECTORDB_CHROMA_PERSIST_DIR=./chroma_data

# Agent Runner (defaults: :8004, gemini:gemini-2.5-flash)
# COLLIDER_AGENT_PROVIDER=gemini
# COLLIDER_AGENT_MODEL=gemini-2.5-flash
# PORT=8004

# NanoClawBridge WebSocket port (default: 18789)
# NANOCLAWBRIDGE_PORT=18789

# CORS Origins (for dev mode)
COLLIDER_CORS_ORIGINS=["http://localhost:4200","http://localhost:4201","http://localhost:4202"]

# API keys: see secrets/api_keys.env.example at repo root
