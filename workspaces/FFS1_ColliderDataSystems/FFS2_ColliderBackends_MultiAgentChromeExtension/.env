# Collider Development Environment

# Data Server
COLLIDER_DATABASE_URL=sqlite+aiosqlite:///./collider.db
COLLIDER_HOST=0.0.0.0
COLLIDER_PORT=8000
COLLIDER_DEBUG=true

# GraphTool Server
GRAPHTOOL_PORT=8001
GRAPHTOOL_DEFAULT_MODEL=gemini:gemini-2.0-flash
GRAPHTOOL_VECTORDB_URL=http://localhost:8002

# VectorDB Server
VECTORDB_PORT=8002
VECTORDB_CHROMA_PERSIST_DIR=./chroma_data

# CORS Origins (for dev mode)
COLLIDER_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3001"]

# Google Gemini API Key (for agent LLM calls)
GOOGLE_API_KEY=your-api-key-here
