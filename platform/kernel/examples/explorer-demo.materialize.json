{
    "actor": "urn:moos:user:demo-seeder",
    "scope": "urn:moos:scope:explorer-demo",
    "apply": true,
    "nodes": [
        {
            "urn": "urn:moos:demo:explorer:ingress",
            "kind": "Node",
            "payload": {
                "label": "Ingress",
                "role": "Authored request boundary"
            },
            "metadata": {
                "demo": true,
                "group": "explorer"
            }
        },
        {
            "urn": "urn:moos:demo:explorer:kernel",
            "kind": "Node",
            "payload": {
                "label": "Kernel Core",
                "role": "Materialized execution node"
            },
            "metadata": {
                "demo": true,
                "group": "explorer"
            }
        },
        {
            "urn": "urn:moos:demo:explorer:surface",
            "kind": "Node",
            "payload": {
                "label": "Projection Surface",
                "role": "Explorer-visible read model"
            },
            "metadata": {
                "demo": true,
                "group": "explorer"
            }
        }
    ],
    "wires": [
        {
            "source_urn": "urn:moos:demo:explorer:ingress",
            "source_port": "out",
            "target_urn": "urn:moos:demo:explorer:kernel",
            "target_port": "in",
            "config": {
                "semantic": "feeds"
            }
        },
        {
            "source_urn": "urn:moos:demo:explorer:kernel",
            "source_port": "out",
            "target_urn": "urn:moos:demo:explorer:surface",
            "target_port": "in",
            "config": {
                "semantic": "projects"
            }
        }
    ]
}